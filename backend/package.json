{
  "name": "vehicle-data-retriever-backend",
  "version": "1.0.0",
  "description": "Backend server for Vehicle Data Retriever Pro",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:parser": "vitest run --grep parser",
    "test:filter": "vitest run --grep filter"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "multer": "^1.4.5-lts.2",
    "playwright": "^1.52.0",
    "socket.io": "^4.8.0",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "async-sema": "^3.1.1",
    "csv-parse": "^5.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
