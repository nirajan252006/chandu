# ==========================================
# Vehicle Data Retriever Pro - Configuration
# ==========================================

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Looker Studio
LOOKER_REPORT_URL=https://lookerstudio.google.com/u/1/reporting/YOUR_REPORT_ID/page/YOUR_PAGE_ID

# Chrome Profile (update to match your system)
CHROME_USER_DATA_DIR=C:\Users\YourUsername\AppData\Local\Google\Chrome\User Data
CHROME_PROFILE=Default

# Automation Settings
MAX_PARALLEL_TABS=3
PAGE_LOAD_TIMEOUT=30000
SEARCH_TIMEOUT=20000
MAX_RETRIES=3
RETRY_DELAY_BASE=2000
THROTTLE_THRESHOLD_MS=15000
AUTO_THROTTLE=true

# Database
DB_PATH=./data/database/vehicle-retriever.db

# File Paths
UPLOAD_DIR=./data/uploads
EXPORT_DIR=./data/exports
LOG_DIR=./data/logs
MAX_UPLOAD_SIZE=52428800

# Browser
HEADLESS=false
BROWSER_SLOWMO=0
